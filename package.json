{
  "name": "ai-ops-for-insurance",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @ai-ops/submission-triage-copilot dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm exec eslint .",
    "symphony:install": "bash ./scripts/install-symphony.sh",
    "symphony:doctor": "bash ./scripts/symphony-doctor.sh",
    "symphony:run": "bash ./scripts/symphony-run.sh",
    "symphony:stop": "bash ./scripts/symphony-stop.sh",
    "deploy:day1": "bash ./scripts/deploy-vercel-app.sh submission-triage-copilot",
    "deploy:day2": "bash ./scripts/deploy-vercel-app.sh portfolio-mix-dashboard",
    "deploy:day3": "bash ./scripts/deploy-vercel-app.sh risk-appetite-parser",
    "deploy:day4": "bash ./scripts/deploy-vercel-app.sh slip-reviewer",
    "deploy:day5": "bash ./scripts/deploy-vercel-app.sh class-of-business-classifier",
    "deploy:day6": "bash ./scripts/deploy-vercel-app.sh exposure-accumulation-heatmap",
    "deploy:day7": "bash ./scripts/deploy-vercel-app.sh cat-event-briefing",
    "deploy:day8": "bash ./scripts/deploy-vercel-app.sh policy-endorsement-diff-checker",
    "deploy:day9": "bash ./scripts/deploy-vercel-app.sh referral-priority-queue-scorer",
    "deploy:day10": "bash ./scripts/deploy-vercel-app.sh claims-fnol-triage-assistant",
    "deploy:day11": "bash ./scripts/deploy-vercel-app.sh binder-capacity-monitor",
    "deploy:day12": "bash ./scripts/deploy-vercel-app.sh treaty-structure-explainer",
    "deploy:day13": "bash ./scripts/deploy-vercel-app.sh exposure-clash-detector",
    "deploy:day14": "bash ./scripts/deploy-vercel-app.sh claims-leakage-flagger",
    "deploy:day15": "bash ./scripts/deploy-vercel-app.sh broker-submission-builder",
    "deploy:day16": "bash ./scripts/deploy-vercel-app.sh exposure-scenario-modeller",
    "deploy:day17": "bash ./scripts/deploy-vercel-app.sh mrc-checker",
    "deploy:day18": "bash ./scripts/deploy-vercel-app.sh placement-tracker",
    "deploy:day19": "bash ./scripts/deploy-vercel-app.sh wording-risk-diff-checker",
    "deploy:app": "bash ./scripts/deploy-vercel-app.sh",
    "predeploy:check": "bash ./scripts/predeploy-check.sh",
    "scaffold:day-app": "bash ./scripts/new-day-app.sh",
    "rag:ingest": "node ./scripts/rag/ingest.mjs",
    "rag:query": "node ./scripts/rag/query.mjs",
    "rag:sync-all": "node ./scripts/rag/sync-all.mjs",
    "format": "prettier --write .",
    "format:md": "prettier --write \"**/*.md\"",
    "lint:md": "markdownlint --ignore node_modules \"**/*.md\"",
    "test:ui:common": "pnpm --filter @ai-ops/common-ui test",
    "test:console:guard": "pnpm playwright test tests/playwright/runtime-console-guard.spec.ts",
    "test:contracts:layout": "pnpm playwright test tests/playwright/intake-layout-contract.spec.ts tests/playwright/csv-pane-border-contract.spec.ts tests/playwright/pane-baseline-alignment.spec.ts",
    "test:contracts:console": "pnpm playwright test tests/playwright/react-key-duplicate-guard.spec.ts tests/playwright/runtime-console-guard.spec.ts",
    "test:contracts:samples": "node ./scripts/qa/check-sample-diversity.mjs",
    "test:contracts:audit": "node ./scripts/qa/check-audit-sequence.mjs",
    "test:visual:day12-14": "bash ./scripts/qa/run-day12-14-visual.sh",
    "test:visual:app": "bash ./scripts/qa/run-app-visual.sh",
    "qa:app": "bash ./scripts/qa/run-app-quality-gates.sh",
    "qa:app:strict": "VERIFY_TIMEOUT_COVERAGE=1 bash ./scripts/qa/run-app-quality-gates.sh",
    "codex:brief": "bash ./scripts/codex/context-brief.sh",
    "codex:resume": "bash ./scripts/codex/resume.sh",
    "supabase:bootstrap:schema": "bash ./scripts/supabase/bootstrap-schema.sh",
    "supabase:bootstrap:all": "bash ./scripts/supabase/bootstrap-all-schemas.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
